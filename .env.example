# PostgreSQL
DATABASE_URL="postgresql://user@localhost:5432/memoization"

# better-auth
BETTER_AUTH_URL="http://localhost:3100"
BETTER_AUTH_SECRET="сгенерируйте: openssl rand -hex 32"

# Sentry (ошибки + console.error/warn). Пусто — мониторинг выключен
VITE_SENTRY_DSN=""
# Для загрузки sourcemaps при сборке
SENTRY_URL=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

