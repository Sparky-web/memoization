# PostgreSQL
DATABASE_URL="postgresql://user@localhost:5432/memoization"

# better-auth
BETTER_AUTH_URL="http://localhost:3100"
BETTER_AUTH_SECRET="сгенерируйте: openssl rand -hex 32"

# ИИ через CLI: codex по умолчанию, claude — резервный провайдер.
AI_PROVIDER="codex"
# Пустые значения используют актуальную модель Codex CLI по умолчанию.
CODEX_GENERATION_MODEL=""
CODEX_CHAT_MODEL=""
CODEX_FAST_MODEL=""

# Sentry (ошибки + console.error/warn). Пусто — мониторинг выключен
VITE_SENTRY_DSN=""
# Для загрузки sourcemaps при сборке
SENTRY_URL=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# --- Прод (VDS, docker-compose) ---
# APP_PORT=<свободный порт на 127.0.0.1, на него смотрит nginx>
# DATABASE_URL="postgresql://memoization:ПАРОЛЬ@host.docker.internal:5432/memoization"
# BETTER_AUTH_URL="https://memoization.studentto.ru"

# Web-push напоминания (VAPID). Пусто — секция уведомлений показывает «скоро».
# Включить: сгенерировать пару `npx web-push generate-vapid-keys`, вписать оба ключа
# и контакт-mailto в SUBJECT, перезапустить приложение (планировщик поднимется сам).
# Час дневного напоминания настраивается пользователем в /app/settings (дефолт 18:00 МСК).
# iOS: уведомления работают только в установленном PWA («На экран „Домой"»), не во вкладке Safari.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"
