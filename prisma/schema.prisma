generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth (better-auth, каноничная схема) ---

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          String   @default("user")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  accounts     Account[]
  sessions     Session[]
  decks        Deck[]
  reviews      Review[]
  cardProgress CardProgress[]
  favorites    DeckFavorite[]

  subscription    Subscription?
  payments        Payment[]
  analyticsEvents AnalyticsEvent[]
  usageEvents     UsageEvent[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id         String @id @default(cuid())
  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  /// bcrypt-хэш для providerId = "credential"
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

// --- Доменная модель: колоды (экзамены), карточки и журнал повторений ---

/// Колода = подготовка к одному экзамену. Принадлежит пользователю; весь прогресс по карточкам — его.
model Deck {
  id          String   @id @default(cuid())
  title       String
  description String?
  /// Сколько раз свайпнуть карточку вправо, чтобы считать её выученной в сессии.
  requiredCorrect Int    @default(2)
  /// Статус колоды: "ready" | "processing" (идёт генерация Claude) | "failed".
  status          String  @default("ready")
  /// Текст ошибки генерации (если status = "failed").
  generationError String?
  /// Статус генерации заданий и тестов: "none" | "processing" | "ready" | "failed".
  exercisesStatus String  @default("none")
  /// Текст ошибки генерации заданий (если exercisesStatus = "failed").
  exercisesError  String?
  /// Колода опубликована — доступна по ссылке /d/:id и её можно добавить в избранное.
  isPublic        Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cards     Card[]
  reviews   Review[]
  fillTasks FillTask[]
  quizTasks QuizTask[]
  favorites DeckFavorite[]

  @@index([userId])
}

/// Карточка: вопрос + ответ. Прогресс повторения теперь у каждого пользователя свой — в CardProgress
/// (чтобы чужую колоду можно было учить по своей ссылке со своим прогрессом).
/// Поля box…lastReviewedAt ниже — историческое состояние владельца (снимок до перехода на CardProgress),
/// код их больше не читает; источник истины — CardProgress.
model Card {
  id       String @id @default(cuid())
  question String
  answer   String
  /// Развёрнутый ответ (markdown) для режима «глубинное изучение»; null — если не сгенерирован.
  answerDeep String?
  /// Порядок добавления (для стабильного показа в списке колоды).
  position Int    @default(0)

  /// Leitner-уровень: 0 — новая, выше — лучше усвоена.
  box Int @default(0)
  /// Коэффициент лёгкости SM-2 (как быстро растёт интервал).
  ease Float @default(2.5)
  /// Текущий интервал до следующего показа, в днях.
  intervalDays Float @default(0)
  /// Когда карточка снова станет к показу. Новая карточка due сразу.
  dueAt DateTime @default(now())
  /// Всего повторений.
  reps         Int @default(0)
  correctCount Int @default(0)
  wrongCount   Int @default(0)
  /// Подряд верных ответов (сбрасывается при «сложно»).
  streak         Int       @default(0)
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  reviews      Review[]
  chatMessages ChatMessage[]
  progress     CardProgress[]

  @@index([deckId, dueAt])
}

/// Прогресс интервального повторения по карточке у конкретного пользователя (SM-2 + Leitner-бокс).
/// Отсутствие строки = карточка для этого пользователя новая и подлежит показу сразу.
model CardProgress {
  id String @id @default(cuid())

  /// Leitner-уровень: 0 — новая, выше — лучше усвоена.
  box Int @default(0)
  /// Коэффициент лёгкости SM-2 (как быстро растёт интервал).
  ease Float @default(2.5)
  /// Текущий интервал до следующего показа, в днях.
  intervalDays Float @default(0)
  /// Когда карточка снова станет к показу.
  dueAt DateTime @default(now())
  /// Всего повторений.
  reps         Int @default(0)
  correctCount Int @default(0)
  wrongCount   Int @default(0)
  /// Подряд верных ответов (сбрасывается при «сложно»).
  streak         Int       @default(0)
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, dueAt])
  @@index([cardId])
}

/// Избранная (чужая) колода: ссылка пользователя на публичную колоду другого автора.
model DeckFavorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([userId, deckId])
  @@index([userId])
  @@index([deckId])
}

/// Журнал каждого свайпа — основа статистики (точность, активность по дням, серия).
model Review {
  id String @id @default(cuid())
  /// "good" (вспомнил, свайп вправо) | "again" (сложно, свайп влево).
  grade      String
  reviewedAt DateTime @default(now())

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deckId, reviewedAt])
  @@index([userId, reviewedAt])
}

/// История чата по теме карточки (вопросы пользователя и ответы Claude).
model ChatMessage {
  id String @id @default(cuid())
  /// "user" — вопрос пользователя | "assistant" — ответ Claude.
  role    String
  content String

  createdAt DateTime @default(now())

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
}

// --- Тренажёр: задания «вставь слово» и тесты (генерируются Claude по материалам) ---

/// Задание «вставь слово»: предложение/определение с пропуском (обозначен «___»).
/// Отвечать можно выбором из вариантов (answer + distractors) или вводом вручную.
model FillTask {
  id          String   @id @default(cuid())
  /// Текст с пропуском; место пропуска — ровно три подчёркивания «___».
  prompt      String
  /// Правильное слово/короткая фраза для пропуска.
  answer      String
  /// Неверные варианты для режима выбора (обычно 3).
  distractors String[]
  /// Порядок добавления (стабильный показ/диагностика).
  position    Int      @default(0)

  /// Накопленная статистика для весов выборки.
  attempts     Int   @default(0)
  correctCount Int   @default(0)
  wrongCount   Int   @default(0)
  /// Вес подмешивания: растёт при ошибке, падает при успехе — спотыкания показываем чаще.
  weight       Float @default(1)
  lastSeenAt   DateTime?
  /// Дизлайк: задание отсеяно пользователем и больше не показывается.
  hidden       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, hidden])
}

/// Тест: вопрос с несколькими вариантами, ровно один правильный (по индексу correctIndex).
model QuizTask {
  id           String   @id @default(cuid())
  question     String
  /// Варианты ответа (обычно 4).
  options      String[]
  /// Индекс правильного варианта в options (0-based).
  correctIndex Int
  /// Короткое пояснение к правильному ответу (необязательно).
  explanation  String?
  position     Int      @default(0)

  attempts     Int   @default(0)
  correctCount Int   @default(0)
  wrongCount   Int   @default(0)
  weight       Float @default(1)
  lastSeenAt   DateTime?
  hidden       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deckId String
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, hidden])
}

// --- Монетизация: подписка Pro, платежи, аналитика, учёт лимитов ---

enum PlanTier {
  FREE
  PRO
}

enum SubscriptionStatus {
  /// Оплачено, currentPeriodEnd в будущем
  ACTIVE
  /// Отменён, но доступ до конца периода
  CANCELED
  /// Период истёк
  EXPIRED
}

enum PaymentProvider {
  YOOKASSA
  /// Ручная выдача Pro администратором
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
  REFUNDED
}

/// Текущее право доступа пользователя. Одна запись на пользователя;
/// апгрейд/продление перезаписывает поля и двигает currentPeriodEnd.
model Subscription {
  id                     String             @id @default(cuid())
  plan                   PlanTier           @default(PRO)
  status                 SubscriptionStatus
  provider               PaymentProvider
  /// id рекуррентного метода/подписки у провайдера; null — разовый доступ
  providerSubscriptionId String?
  /// До какого момента открыт Pro
  currentPeriodEnd       DateTime
  /// true — не продлевать (разовый доступ или отменённый рекуррент)
  cancelAtPeriodEnd      Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentPeriodEnd])
}

/// Журнал платежей. providerPaymentId уникален — на нём идемпотентность вебхука.
model Payment {
  id                String          @id @default(cuid())
  provider          PaymentProvider
  providerPaymentId String          @unique
  amount            Int             // в копейках
  currency          String          @default("RUB")
  status            PaymentStatus
  plan              PlanTier
  /// Сколько дней доступа докупается этим платежом (для разовых)
  periodDays        Int?
  /// Назначение платежа — то же, что ушло в чек 54-ФЗ
  description       String?
  refundedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Продуктовая аналитика: paywall/чекаут/оплаты. Пользователь удаляется — события остаются.
model AnalyticsEvent {
  id   String @id @default(cuid())
  name String
  meta Json?

  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId, createdAt])
}

/// Учёт использования платных ИИ-функций — на нём лимиты Free и fair-use Pro.
/// kind: "deck_generation" | "exercise_generation" | "chat_message".
model UsageEvent {
  id   String @id @default(cuid())
  kind String
  /// Для генераций — id колоды (по нему компенсация при неудаче), для чата — id карточки.
  refId String?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, createdAt])
}
