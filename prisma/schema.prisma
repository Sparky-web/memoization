generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth (better-auth, каноничная схема) ---

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          String   @default("user")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  accounts     Account[]
  sessions     Session[]
  exams        Exam[]
  reviews      Review[]
  cardProgress CardProgress[]
  favorites    ExamFavorite[]
  anxietyDumps AnxietyDump[]
  streakDays   StreakDay[]
  settings     UserSettings?

  subscription    Subscription?
  payments        Payment[]
  analyticsEvents AnalyticsEvent[]
  usageEvents     UsageEvent[]

  pushSubscriptions PushSubscription[]
  pushLogs          PushLog[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id         String @id @default(cuid())
  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  /// bcrypt-хэш для providerId = "credential"
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

// --- Доменная модель «Домашник»: экзамен → вопросы → карточки → FSRS-прогресс и журнал ---

/// Экзамен — центральная сущность: список вопросов + дата + материалы.
/// При миграции id = старый Deck.id (публичные ссылки и редиректы бесплатно).
model Exam {
  id          String    @id @default(cuid())
  title       String
  description String?
  /// null — без даты (мигрированные колоды; режим поддерживающего повторения).
  examDate    DateTime?
  /// Цель: «сдать» / «4» / «5» — свободная строка.
  targetGrade String?
  dailyMinutes Int      @default(25)
  /// "oral" | "written" | "test" | null — смещение пропорций форматов карточек.
  examFormat  String?
  /// Статус генерации: "draft" | "processing" | "ready" | "failed".
  status          String  @default("ready")
  generationError String?
  /// "long" — долгая подготовка | "cram" — умная зубрёжка (Pro).
  mode     String  @default("long")
  /// Экзамен опубликован — доступен по ссылке /d/:id, его можно форкнуть.
  isPublic Boolean @default(false)
  /// Прошёл экзамен — экзамен в архиве (скрыт из плана дня).
  archivedAt DateTime?
  /// На паузе — исключён из плана дня и предложений, но не архивирован (лимит активных не ест).
  pausedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questions      Question[]
  cards          Card[]
  materials      Material[]
  favorites      ExamFavorite[]
  forecastChecks ForecastCheck[]
  teachSessions  TeachSession[]
  conceptMaps    ConceptMap[]
  memoryPalaces  MemoryPalace[]

  @@index([userId])
}

/// Исходный вопрос из списка к экзамену; тема — кластер для интерливинга и готовности по темам.
model Question {
  id       String @id @default(cuid())
  position Int
  text     String
  /// Тема-кластер (ИИ группирует вопросы в 4–8 тем).
  topic    String?
  /// Сгенерированный полный ответ (markdown, страница вопроса).
  answerMd String?
  /// false — материалы пользователя не покрыли вопрос (ответ из общих знаний, плашка в UI).
  covered     Boolean @default(true)
  /// false — ответ построен из материалов пользователя.
  aiGenerated Boolean @default(true)
  /// «файл.pdf · короткая цитата» — привязка ответа к материалу.
  sourceRef   String?

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  cards Card[]

  @@index([examId, position])
}

/// Загруженный материал (конспект): файл лежит на диске, в БД — метаданные.
model Material {
  id        String @id @default(cuid())
  fileName  String
  mimeType  String
  sizeBytes Int
  /// data/materials/<examId>/<materialId>_<safe-name>
  storagePath String

  createdAt DateTime @default(now())

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
}

/// Атомарная карточка: один факт — одна карточка. id при миграции = старый Card.id (ChatMessage живёт).
model Card {
  id     String @id @default(cuid())
  /// "open" | "mcq" | "cloze" | "truefalse".
  format String
  /// Вопрос карточки; для cloze — текст с пропуском «___».
  prompt String
  /// Верный ответ (краткий); для truefalse — "true"/"false".
  answer String
  /// mcq/cloze: ВСЕ варианты выбора; правильный проверяется на сервере по тексту (анти-чит).
  options String[]
  /// Однострочное «почему» для немедленной обратной связи.
  explanation String?
  /// Развёрнутый разбор (markdown; из старого answerDeep).
  deepMd   String?
  /// Ключевая ассоциация (мнемоника).
  mnemonic String?
  /// «файл.pdf · цитата» — источник факта в материалах.
  sourceRef   String?
  aiGenerated Boolean @default(false)
  /// «Проверить» — пользователь сомневается в ответе ИИ (анти-галлюцинации).
  flagged   Boolean @default(false)
  /// Выключена из сессий (из старого hidden).
  suspended Boolean @default(false)
  position  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examId     String
  exam       Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId String?
  question   Question? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  progress      CardProgress[]
  reviews       Review[]
  chatMessages  ChatMessage[]
  memoryPalaces MemoryPalace[]

  @@index([examId, position])
}

/// FSRS-состояние карточки у конкретного пользователя. Отсутствие строки = карточка новая.
model CardProgress {
  id String @id @default(cuid())

  stability  Float    @default(0)
  difficulty Float    @default(0)
  due        DateTime @default(now())
  /// ts-fsrs State: 0 New / 1 Learning / 2 Review / 3 Relearning.
  state  Int @default(0)
  reps   Int @default(0)
  lapses Int @default(0)
  lastReviewedAt DateTime?
  /// Successive relearning: в скольких РАЗНЫХ днях МСК был верный ответ (инкремент максимум раз в день).
  masteredDays Int @default(0)
  /// Уверенный промах → в приоритет ближайшей сессии; сбрасывается верным ответом.
  priority Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, due])
}

/// Журнал каждого ответа — источник готовности, серий и аналитики.
model Review {
  id String @id @default(cuid())
  /// FSRS: 1 Again / 2 Hard / 3 Good / 4 Easy.
  rating  Int
  correct Boolean
  /// Уверенность 0..100 (ползунок ДО показа ответа).
  confidence Int?
  /// Введённый открытый ответ.
  answerText String?
  /// "match" | "partial" | "miss" — вердикт ИИ-сверки открытого ответа (Pro).
  aiVerdict String?
  /// "daily" | "pretest" | "cram" | "bedtime".
  mode       String   @default("daily")
  durationMs Int?
  reviewedAt DateTime @default(now())

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Денормализация для агрегатов по экзамену (каскад придёт через Card).
  examId String

  @@index([userId, reviewedAt])
  @@index([examId, reviewedAt])
  @@index([cardId])
}

/// «Прогноз против факта»: предсказанный процент до сессии и реальный после.
model ForecastCheck {
  id               String    @id @default(cuid())
  userId           String
  predictedPercent Int
  actualPercent    Int?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Сессия «объясни ученику» (текст или голос).
model TeachSession {
  id        String   @id @default(cuid())
  userId    String
  topic     String?
  summaryMd String?
  voice     Boolean  @default(false)
  createdAt DateTime @default(now())

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  turns TeachTurn[]

  @@index([userId, createdAt])
}

model TeachTurn {
  id String @id @default(cuid())
  /// "user" — объяснение пользователя | "student" — реплика ученика.
  role      String
  content   String
  createdAt DateTime @default(now())

  sessionId String
  session   TeachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

/// Карта связей: узлы и рёбра в JSON ([{id,label,x,y}] / [{from,to,label}]).
model ConceptMap {
  id     String @id @default(cuid())
  userId String
  title  String
  nodes  Json
  edges  Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Дворец памяти: маршрут локусов в JSON ([{place,item,image}]).
model MemoryPalace {
  id     String @id @default(cuid())
  userId String
  title  String
  loci   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  cardId String?
  card   Card?   @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([userId])
}

/// Выгрузка тревог перед экзаменом (экспрессивное письмо).
model AnxietyDump {
  id      String  @id @default(cuid())
  examId  String?
  content String  @db.Text

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Избранный (чужой публичный) экзамен — данные мигрированы из DeckFavorite.
model ExamFavorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([userId, examId])
  @@index([examId])
}

/// Журнал серии дней: kind "done" — план дня закрыт (день засчитан и при < 10 ответах),
/// kind "freeze" — пропуск закрыт заморозкой (durable-автосписание). dayKey — день МСК YYYY-MM-DD.
model StreakDay {
  id String @id @default(cuid())
  /// Ключ календарного дня МСК (см. mskDayKey).
  dayKey String
  /// "done" | "freeze".
  kind      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayKey])
}

/// Настройки пользователя: дневной бюджет, дни отдыха, предсонное напоминание, ИИ-сверка.
/// Заморозки серии живут в журнале StreakDay (остаток считается на скользящие 30 дней).
model UserSettings {
  id String @id @default(cuid())
  /// Общий дневной бюджет минут на все экзамены.
  dailyMinutesTotal Int @default(25)
  /// Запланированные дни отдыха (0 — воскресенье … 6 — суббота, счёт по МСК) — не рвут серию.
  restWeekdays Int[] @default([])
  /// Час предсонного напоминания по МСК (null — выключено; без строки настроек действует дефолт 21).
  bedtimeHour Int? @default(21)
  /// ИИ-сверка открытых ответов (Pro): сервер сверяет ответ с эталоном по смыслу (волна 5).
  aiCheckEnabled Boolean @default(false)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Web-push подписка браузера: endpoint уникален глобально (один браузер — одна запись).
model PushSubscription {
  id String @id @default(cuid())

  endpoint  String  @unique
  p256dh    String
  auth      String
  userAgent String?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Журнал отправленных пушей: уникальность (userId, kind, dayKey) — дедуп «не чаще раза в день».
model PushLog {
  id String @id @default(cuid())

  /// "daily" | "bedtime" | "exam_eve".
  kind   String
  /// Ключ календарного дня МСК (см. mskDayKey).
  dayKey String

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, dayKey])
}

/// История чата по карточке («вопрос по карточке» / «объясни почему»).
model ChatMessage {
  id String @id @default(cuid())
  /// "user" — вопрос пользователя | "assistant" — ответ Claude.
  role    String
  content String

  createdAt DateTime @default(now())

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, createdAt])
}

// --- Монетизация: подписка Pro, платежи, аналитика, учёт лимитов ---

enum PlanTier {
  FREE
  PRO
}

enum SubscriptionStatus {
  /// Оплачено, currentPeriodEnd в будущем
  ACTIVE
  /// Отменён, но доступ до конца периода
  CANCELED
  /// Период истёк
  EXPIRED
}

enum PaymentProvider {
  YOOKASSA
  /// Ручная выдача Pro администратором
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
  REFUNDED
}

/// Текущее право доступа пользователя. Одна запись на пользователя;
/// апгрейд/продление перезаписывает поля и двигает currentPeriodEnd.
model Subscription {
  id                     String             @id @default(cuid())
  plan                   PlanTier           @default(PRO)
  status                 SubscriptionStatus
  provider               PaymentProvider
  /// id рекуррентного метода/подписки у провайдера; null — разовый доступ
  providerSubscriptionId String?
  /// До какого момента открыт Pro; null — безлимитный Pro (выдаётся только админом)
  currentPeriodEnd       DateTime?
  /// true — не продлевать (разовый доступ или отменённый рекуррент)
  cancelAtPeriodEnd      Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentPeriodEnd])
}

/// Журнал платежей. providerPaymentId уникален — на нём идемпотентность вебхука.
model Payment {
  id                String          @id @default(cuid())
  provider          PaymentProvider
  providerPaymentId String          @unique
  amount            Int             // в копейках
  currency          String          @default("RUB")
  status            PaymentStatus
  plan              PlanTier
  /// Сколько дней доступа докупается этим платежом (для разовых)
  periodDays        Int?
  /// Назначение платежа — то же, что ушло в чек 54-ФЗ
  description       String?
  refundedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Продуктовая аналитика: paywall/чекаут/оплаты. Пользователь удаляется — события остаются.
model AnalyticsEvent {
  id   String @id @default(cuid())
  name String
  meta Json?

  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([userId, createdAt])
}

/// Учёт использования платных ИИ-функций — на нём лимиты Free и fair-use Pro.
/// kind: "deck_generation" (генерация экзамена; имя историческое) | "card_regeneration"
/// | "chat_message" (чат, «объясни ученику/почему», черновики карт, образы дворца)
/// | "ai_check" (ИИ-сверка открытых ответов, отдельная квота).
model UsageEvent {
  id   String @id @default(cuid())
  kind String
  /// Для генераций — id экзамена (по нему компенсация при неудаче), для чата — id карточки.
  refId String?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind, createdAt])
}
